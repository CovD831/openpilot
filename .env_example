# OpenPilot environment example.
# Copy this file to .env and replace blank secret values locally.

# Chat LLM settings for an OpenAI-compatible endpoint.
OPENPILOT_LLM_PROVIDER=openai-compatible
OPENPILOT_LLM_BASE_URL=https://api.openai.com/v1
OPENPILOT_LLM_API_KEY=
OPENPILOT_LLM_MODEL=gpt-4o-mini
OPENPILOT_LLM_TIMEOUT_SECONDS=60
OPENPILOT_LLM_TEMPERATURE=0.2
OPENPILOT_LLM_TRANSPORT_RETRIES=2
OPENPILOT_LLM_RETRY_INITIAL_DELAY=2
OPENPILOT_LLM_RETRY_MAX_DELAY=20

# Embedding settings.
# Leave the endpoint and key blank to inherit the LLM base URL and API key.
OPENPILOT_EMBEDDING_PROVIDER=openai-compatible
OPENPILOT_EMBEDDING_BASE_URL=
OPENPILOT_EMBEDDING_API_KEY=
OPENPILOT_EMBEDDING_MODEL=text-embedding-3-small
OPENPILOT_EMBEDDING_TIMEOUT_SECONDS=30

# Optional proxy settings used by network clients and web search diagnostics.
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
