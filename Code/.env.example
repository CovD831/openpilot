# OpenPilot LLM Configuration
# 复制此文件为 .env 并填入你的配置

# LLM Provider (openai-compatible)
OPENPILOT_LLM_PROVIDER=openai-compatible

# API Base URL
# OpenAI: https://api.openai.com/v1
# Azure OpenAI: https://your-resource.openai.azure.com/
# Ollama: http://localhost:11434/v1
OPENPILOT_LLM_BASE_URL=https://api.openai.com/v1

# API Key (必需)
# 从你的 LLM 提供商获取
OPENPILOT_LLM_API_KEY=

# Model Name
# OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# Azure: your-deployment-name
# Ollama: llama2, mistral, etc.
OPENPILOT_LLM_MODEL=gpt-4o-mini

# Request Timeout (seconds)
OPENPILOT_LLM_TIMEOUT_SECONDS=60

# Temperature (0.0 - 2.0)
# 较低的值（如 0.2）更确定性，较高的值（如 0.8）更有创造性
OPENPILOT_LLM_TEMPERATURE=0.2

# ⚠️ 安全提示：
# 1. 永远不要提交包含真实 API key 的 .env 文件到 Git
# 2. 将 .env 添加到 .gitignore
# 3. 定期轮换你的 API key
