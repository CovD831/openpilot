          "default": null
        },
        {
          "name": "pattern",
          "type": "string",
          "description": "Glob pattern used with directory_path",
          "required": false,
          "default": "*完成报告*.md"
        },
        {
          "name": "encoding",
          "type": "string",
          "description": "File encoding",
          "required": false,
          "default": "utf-8"
        },
        {
          "name": "max_total_chars",
          "type": "integer",
          "description": "Maximum combined content length",
          "required": false,
          "default": 50000
        }
      ],
      "output_schema": {
        "type": "object",
        "description": "Combined file contents and metadata",
        "properties": {
          "content": {
            "type": "string",
            "description": "Combined file contents"
          },
          "files": {
            "type": "array",
            "description": "Read file paths"
          },
          "count": {
            "type": "integer",
            "description": "Number of files read"
          },
          "truncated": {
            "type": "boolean",
            "description": "Whether content was truncated"
          }
        }
      },
      "failure_modes": [
        {
          "error_type": "file_not_found",
          "description": "One or more files do not exist",
          "recovery_strategy": "Check file paths and retry"
        },
        {
          "error_type": "encoding_error",
          "description": "Cannot decode a file with specified encoding",
          "recovery_strategy": "Try a different encoding"
        }
      ],
      "timeout_seconds": 60,
      "max_retries": 2,
      "tags": [
        "file",
        "read",
        "batch",
        "local",
        "io"
      ],
      "audit_required": true
    },
    {
      "tool_name": "file_writer",
      "display_name": "File Writer",
      "function": "Write contents to a local file",
      "version": "1.0.0",
      "capabilities": [
        "file_write"
      ],
      "permission_level": "medium",
      "input_schema": [
        {
          "name": "file_path",
          "type": "string",
          "description": "Absolute or relative path to the file",
          "required": true,
          "default": null
        },
        {
          "name": "content",
          "type": "string",
          "description": "Content to write to file",
          "required": true,
          "default": null
        },
        {
          "name": "encoding",
          "type": "string",
          "description": "File encoding (default: utf-8)",
          "required": false,
          "default": "utf-8"
        },
        {
          "name": "create_dirs",
          "type": "boolean",
          "description": "Create parent directories if they don't exist",
          "required": false,
          "default": true
        },
        {
          "name": "overwrite",
          "type": "boolean",
          "description": "Overwrite file if it exists",
          "required": false,
          "default": true
        }
      ],
      "output_schema": {
        "type": "object",
        "description": "Write result and metadata",
        "properties": {
          "file_path": {
            "type": "string",
            "description": "Path to written file"
          },
          "bytes_written": {
            "type": "integer",
            "description": "Number of bytes written"
          },
          "created": {
            "type": "boolean",
            "description": "Whether file was newly created"
          }
        }
      },
      "failure_modes": [
        {
          "error_type": "permission_denied",
          "description": "No permission to write file",
          "recovery_strategy": "Check file/directory permissions"
        },
        {
          "error_type": "file_exists",
          "description": "File exists and overwrite=False",
          "recovery_strategy": "Set overwrite=True or choose different path"
        },
        {
          "error_type": "disk_full",
          "description": "Not enough disk space",
          "recovery_strategy": "Free up disk space or write to different location"
        }
      ],
      "timeout_seconds": 30,
      "max_retries": 2,
      "tags": [
        "file",
        "write",
        "local",
        "io"
      ],
      "audit_required": true
    },
    {
      "tool_name": "llm_summarizer",
      "display_name": "LLM Summarizer",
      "function": "Generate summary or analysis using LLM",
      "version": "1.0.0",
      "capabilities": [
        "llm_call"
      ],
      "permission_level": "low",
      "input_schema": [
        {
          "name": "text",
